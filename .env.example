# Qwen / DashScope credentials
# Fill ONE key variable only. Never commit the real value.
AWARELIQUID_LLM_API_KEY=填入你的千问_API_Key
# DASHSCOPE_API_KEY=填入你的千问_API_Key

# Qwen OpenAI-compatible endpoint
AWARELIQUID_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AWARELIQUID_LLM_MODEL=qwen-plus
AWARELIQUID_LLM_BACKEND=qwen

# --- Formal (competition-mode) run controls -------------------------------
# NOTE: nothing here is auto-loaded; there is no python-dotenv in this project.
# Export these in your shell, or source this file yourself.

# Network egress for a formal run is DENIED BY DEFAULT. submit.py always runs in
# competition mode, so without this set to exactly "1" it exits immediately with
# an explanatory message (it used to die on the first question instead).
#   bash:       export AWARELIQUID_ALLOW_FORMAL_NETWORK=1
#   PowerShell: $env:AWARELIQUID_ALLOW_FORMAL_NETWORK="1"
AWARELIQUID_ALLOW_FORMAL_NETWORK=0

# Force formal gates on for a non-submit entry point (submit.py sets this itself).
# AWARELIQUID_COMPETITION_MODE=1

# Allow the offline mock backend. Requires AWARELIQUID_LLM_BACKEND=mock, and is
# refused outright in competition mode.
# AWARELIQUID_TEST_MODE=1

# Identify the run and where its 5,000,000-token ledger lives. submit.py derives
# both from the question file and --out when unset. The ledger records REAL
# spend and survives --fresh; zero it only with `submit.py --reset-ledger`.
# AWARELIQUID_FORMAL_RUN_ID=afac-submit-xxxxxxxx
# AWARELIQUID_FORMAL_LEDGER_PATH=submission.csv.usage.json

# Non-formal ledger path (rejected in competition mode).
# AWARELIQUID_USAGE_LEDGER_PATH=usage.json

# Endpoint provider label, for a non-DashScope OpenAI-compatible Qwen gateway.
# AWARELIQUID_LLM_PROVIDER=qwen
